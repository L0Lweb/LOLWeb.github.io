---
---
{
    "functions": {{ site.data.functions | jsonify -}},
    "contexts": {{ site.data.contexts | jsonify -}},
    "executables": {
        {%- for lolweb in site.lolwebs -%}
            {%- capture name -%}{%- include get_lolweb_name.html path=lolweb.path -%}{%- endcapture -%}
            {{ name | jsonify -}}: {
                {%- assign root_fields = 'comment,functions,alias' | split: ',' -%}
                {%- assign comma = false -%}
                {%- for field in root_fields -%}
                    {%- if lolweb[field] -%}
                        {%- if comma -%},{%- endif -%}
                        {%- assign comma = true -%}
                        {{- field | jsonify -}}: {{- lolweb[field] | jsonify -}}
                    {%- endif -%}
                {%- endfor -%}
            }
            {%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
    }
}
